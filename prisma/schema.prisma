// =============================================================================
// schema.prisma — Time-Off Microservice Data Model
// Layer 4 artifact. Owned by L4. Used by L7 (Implementation).
//
// Production path: prisma/schema.prisma  (project root)
// This file lives in discussion/ during the design phase; L7 copies it to
// prisma/schema.prisma when initialising the project.
//
// Infrastructure notes (L1.1.1-A DB-1 / DB-2):
//   - ORM: Prisma (locked decision, not revisable)
//   - DATABASE_URL read by PrismaClient directly from environment
//   - WAL mode: CANNOT be set here; applied in PrismaService.onModuleInit()
//     via `this.$executeRawUnsafe('PRAGMA journal_mode=WAL')`
//   - Migrations: `prisma migrate dev` (local), `prisma migrate deploy` (CI/prod)
//   - `prisma db push` is FORBIDDEN in all persistent environments
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// SQLite has no native enum type. Prisma does not support enum declarations with
// the sqlite provider — attempting to declare enums causes error P1012 at
// prisma generate time. These three enums are therefore defined as TypeScript
// enum objects in src/common/types/ and enforced at the application layer only.
// The corresponding database columns are TEXT (String in Prisma).
//
// TypeScript enum locations:
//   RequestState    → src/common/types/request-state.enum.ts
//   AuditEventType  → src/common/types/audit-event.interface.ts
//   AuditSeverity   → src/common/types/audit-event.interface.ts
//
// All modules import these enums from '../common/types' — NOT from '@prisma/client'.
// =============================================================================

// =============================================================================
// MODEL: TimeOffRequest
// Table: time_off_request
// The core table tracking every time-off request from submission through a
// terminal state. Serves as the pending deduction ledger (L1-adr Decision 2).
// =============================================================================

model TimeOffRequest {
  // ── Identity ─────────────────────────────────────────────────────────────
  // UUID generated by this service at submission. Sent to HCM as `requestId`
  // on every POST attempt. Exposed as `requestId` in the L3 API (C-5).
  // Immutable after creation.
  id               String       @id @default(uuid()) @map("id")

  // ── Immutable business fields (locked at submission; L1-adr Decision 2) ──
  employeeId       String       @map("employee_id")
  locationId       String       @map("location_id")
  requestedDays    Float        @map("requested_days")
  submittedAt      DateTime     @default(now()) @map("submitted_at")

  // Caller-supplied deduplication key (Idempotency-Key header). Unique
  // constraint enables O(1) duplicate detection. Immutable after creation.
  idempotencyKey   String       @unique @map("idempotency_key")

  // ── Mutable lifecycle fields ──────────────────────────────────────────────
  state            String       @map("state")

  // Set to true when post-validation (L1-adr Decision 4) detects a zero or
  // negative `balanceDays` in the HCM 200 response. Does not change state.
  integrityFlag    Boolean      @default(false) @map("integrity_flag")

  // HTTP status from HCM on the decisive response (200, 422, 404, 401, 403).
  // Null for states where no HCM call has completed (e.g., REJECTED_PRE_VALIDATION
  // or transient states). Exposed in API as `hcmOutcomeStatus`.
  hcmOutcomeStatus Int?         @map("hcm_outcome_status")

  // Timestamp when the request reached a terminal state. Null while transient.
  resolvedAt       DateTime?    @map("resolved_at")

  // ── Internal reconciliation fields (NEVER exposed in API responses) ──────
  // Per-request snapshot of the global sync cursor captured immediately before
  // each POST attempt. Used as `since` parameter on reconciliation delta sync
  // (L1-adr Decision 3). Updated on every retry; never set after a POST is sent.
  hcmPrePostSequence  Int?      @map("hcm_pre_post_sequence")

  // Total number of POST dispatches. Incremented before each attempt. Used
  // with `firstPostAttemptAt` to enforce retry limits (L1-adr Decision 3).
  postAttemptCount    Int       @default(0) @map("post_attempt_count")

  // Timestamp of the first POST attempt. Immutable after first write.
  // Anchors the one-hour retry window (L1-adr Decision 3).
  firstPostAttemptAt  DateTime? @map("first_post_attempt_at")

  // Earliest timestamp at which a 429-delayed retry is eligible.
  // Persisted so restart recovery (FM-12) can reschedule correctly (L1-adr D3).
  retryNotBefore      DateTime? @map("retry_not_before")

  // ── Standard timestamps ───────────────────────────────────────────────────
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // ── Indexes ───────────────────────────────────────────────────────────────
  // Covers the effective balance computation query on every balance read and
  // every submission pre-validation:
  //   SELECT SUM(requested_days) FROM time_off_request
  //   WHERE state IN ('PENDING_HCM','NEEDS_RECONCILIATION')
  //     AND employee_id = ? AND location_id = ?
  @@index([employeeId, locationId, state], map: "idx_time_off_request_balance_query")

  // Covers the reconciliation startup scan (L1-adr Decision 3 — FM-12):
  //   SELECT * FROM time_off_request
  //   WHERE state IN ('PENDING_HCM','NEEDS_RECONCILIATION')
  // Runs on every service restart inside onApplicationBootstrap.
  @@index([state], map: "idx_time_off_request_state")

  @@map("time_off_request")
}

// =============================================================================
// MODEL: BalanceCache
// Table: balance_cache
// One row per (employeeId, locationId) pair. Local copy of HCM balance state.
// Raw balance only — never mutated to reflect pending reservations. The
// effective available balance is computed at read time from this value minus
// the sum of active reservations in TimeOffRequest (L1-adr Decision 1 / D2).
// =============================================================================

model BalanceCache {
  employeeId      String   @map("employee_id")
  locationId      String   @map("location_id")

  // Raw projected balance as last received from HCM. Never modified to
  // account for pending deductions. Worst-case staleness: 30 seconds in
  // steady state. Exposed as `rawCachedBalanceDays` in L3 C-4.
  balanceDays     Float    @map("balance_days")

  // Global HCM sequence number for this record (the highest `lastSequence`
  // applied from HCM). Used for stale push detection and as the per-record
  // cursor contribution. Exposed as `lastHcmSequence` in L3 C-4.
  lastHcmSequence Int      @map("last_hcm_sequence")

  // Timestamp of the last successful sync event that updated this row.
  // Exposed as `lastSyncedAt` in L3 C-4.
  lastSyncedAt    DateTime @map("last_synced_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Composite primary key: one row per unique (employeeId, locationId) pair.
  // PK serves as the lookup index for Endpoint 1 (GET /balances/:eid/:lid).
  @@id([employeeId, locationId])
  @@map("balance_cache")
}

// =============================================================================
// MODEL: SyncState
// Table: sync_state
// Singleton table (always exactly one row with id = "singleton").
// Persists the global HCM sync cursor and last successful sync timestamp.
// Required by L1-adr Decision 1 (cursor must survive restarts) and L3
// Endpoint 8b (lastSuccessfulSyncAt must be database-persisted, not in-memory).
// =============================================================================

model SyncState {
  // Fixed value "singleton". Application always upserts with this id.
  id                   String    @id @default("singleton") @map("id")

  // The global HCM sequence cursor: the highest `lastSequence` seen across
  // all received balance records and ledger events. Written in the same atomic
  // SQLite transaction as the cache update it corresponds to (L1-adr D1).
  // Null only before the first successful sync (FM-09 cursor-loss recovery).
  globalCursor         Int?      @map("global_cursor")

  // Timestamp of the last successful delta sync cycle. Written by the sync
  // engine after every successful poll. Read by the health module on every
  // GET /health/ready request (L1.1.1 Section 6.3 — must be DB-persisted).
  lastSuccessfulSyncAt DateTime? @map("last_successful_sync_at")

  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("sync_state")
}

// =============================================================================
// MODEL: AuditLog
// Table: audit_log
// Append-only record of all security and integrity events. Implements the
// two-phase archival pattern (L1.1.1 Section 5.6): active records have
// archivedAt = NULL; archived records have archivedAt = <timestamp>.
//
// APPEND-ONLY ENFORCEMENT (L1-adr Decision 6):
//   Layer 1 — Application: AuditService exposes no update/delete methods.
//     Authorised operations: create(), findMany(), updateMany() for archival
//     (NULL → non-null archivedAt only), deleteMany() for expired archived rows.
//   Layer 2 — Database triggers (L7 responsibility, cannot be expressed in
//     schema.prisma): see Forward Constraints for L7 below.
//
// INDEXES: All three required indexes are partial indexes (WHERE clause).
//   Prisma @@index does not support partial indexes. These MUST be created
//   via raw SQL in the initial migration file by L7. See Forward Constraints.
//   No @@index directives appear on this model to avoid creating inferior
//   full-table indexes that would need to be dropped and replaced.
// =============================================================================

model AuditLog {
  // ── Universal fields (every event type) ──────────────────────────────────
  id              String         @id @default(uuid()) @map("id")
  eventType       String         @map("event_type")

  // When the triggering condition was detected (not when this row was written).
  occurredAt      DateTime       @map("occurred_at")

  severity        String         @map("severity")

  // One of: "push-verification", "deduction-flow", "sync-engine"
  sourceSubsystem String         @map("source_subsystem")

  // ── Optional context references ──────────────────────────────────────────
  // Dedicated nullable column for efficient filtering (Endpoint 9 filter) and
  // the partial index on (employeeId, occurredAt). Present for events that
  // involve a specific employee (INTEGRITY_*, CREDENTIAL_ERROR, REQUEST_EXHAUSTED,
  // SYNC_RESET_INVALID). Absent for push security events.
  employeeId      String?        @map("employee_id")

  // Nullable reference to the triggering TimeOffRequest. Not a foreign key —
  // audit records must outlive request records. Present for events that involve
  // a specific request (INTEGRITY_*, CREDENTIAL_ERROR, REQUEST_EXHAUSTED).
  // Not indexed (no Endpoint 9 filter parameter for requestId).
  requestId       String?        @map("request_id")

  // ── Per-event variable context ────────────────────────────────────────────
  // JSON object stored as TEXT. Shape is event-type-specific per L1-adr D6.
  // CRITICAL: HMAC digest values must NEVER appear in this field (L1-adr D5).
  context         String         @map("context")

  // ── Two-phase archival ────────────────────────────────────────────────────
  // NULL  → active record (0–activeWindowDays, default 90 days)
  // non-NULL → archived record (still queryable; set by nightly archival job)
  // Records with archivedAt older than retentionDays are permanently deleted
  // by the same job. Default NULL; must not be set via create() calls.
  archivedAt      DateTime?      @map("archived_at")

  // No @@index here. All indexes on this table are partial indexes that must
  // be added via raw SQL migration. See Forward Constraints for L7.
  @@map("audit_log")
}
