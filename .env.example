# Database
DATABASE_URL=file:./dev.db

# HCM Integration
HCM_API_KEY=your-hcm-api-key-here-min-32-chars
HCM_BASE_URL=http://localhost:4000
HCM_WEBHOOK_SECRET=your-webhook-secret-here-min-32-chars
HCM_TIMEOUT_MS=5000

# Service Authentication (must not be identical to each other; min 32 chars each)
SERVICE_API_KEY=your-service-api-key-here-min-32-chars
ADMIN_API_KEY=your-admin-api-key-here-min-32-chars

# Audit Log Retention
AUDIT_RETENTION_DAYS=365
AUDIT_ARCHIVE_CRON=0 3 * * *
AUDIT_ACTIVE_DAYS=90

# Logging
LOG_LEVEL=info

# CORS (optional — comma-separated origins; omit to disable CORS)
# CORS_ALLOWED_ORIGINS=http://localhost:3001,https://app.example.com

# Body Parsing
BODY_SIZE_LIMIT=1mb
JSON_MAX_DEPTH=20

# Rate Limiting (per 60-second window, per X-API-Key)
THROTTLE_BALANCE_READ_LIMIT=120
THROTTLE_SUBMIT_LIMIT=30
THROTTLE_STATUS_QUERY_LIMIT=60
THROTTLE_AUDIT_QUERY_LIMIT=20
THROTTLE_MANUAL_SYNC_LIMIT=5
THROTTLE_MANUAL_RECON_LIMIT=10

# Service metadata
SERVICE_VERSION=1.0.0
